// Deployment routing config
{
  "version": 2,

  // Internal project name
  "name": "streamgate",

  // Send every request to the main API handler
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ],

  // Keep clean URLs without forced trailing slash
  "trailingSlash": false
}
